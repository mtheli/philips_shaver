      "show_capabilities": {
        "title": "Hardware-Fähigkeiten erkannt",
        "description": "Erfolgreich mit **{name}** verbunden.\n\n**Hardware-Fähigkeiten:**\n{capabilities}\n\n**GATT Service Status:**\n{services}\n\n**Legende:**\n✅ Service gefunden & unterstützt\n❌ Erwarteter Service fehlt\n❔ Unbekannter Service vom Gerät\n\nKlicken Sie auf Absenden, um die Einrichtung abzuschließen."
      }
    },
    "error": {
      "abort_if_unique_id_configured": "Das Gerät ist bereits konfiguriert.",
